{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/max-elia/cspp/schemas/instance-payload.schema.json",
  "title": "CSPP instance payload",
  "type": "object",
  "required": ["schema_version", "warehouse", "stores", "demand_rows"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "instance_id": {
      "type": "string",
      "minLength": 1
    },
    "warehouse": {
      "type": "object",
      "required": ["latitude", "longitude"],
      "additionalProperties": true,
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "stores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["client_num", "latitude", "longitude"],
        "additionalProperties": true,
        "properties": {
          "client_num": { "type": "integer", "minimum": 1 },
          "store_id": { "type": ["string", "number", "null"] },
          "store_name": { "type": ["string", "null"] },
          "street": { "type": ["string", "null"] },
          "postal_code": { "type": ["string", "number", "null"] },
          "city": { "type": ["string", "null"] },
          "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
          "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
          "cluster_id": { "type": ["integer", "null"], "minimum": 0 },
          "total_demand_kg": { "type": ["number", "null"], "minimum": 0 },
          "max_demand_kg": { "type": ["number", "null"], "minimum": 0 },
          "active_days": { "type": ["integer", "null"], "minimum": 0 }
        }
      }
    },
    "demand_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["delivery_date", "client_num", "demand_kg"],
        "additionalProperties": true,
        "properties": {
          "delivery_date": { "type": "string", "minLength": 1 },
          "client_num": { "type": "integer", "minimum": 1 },
          "store_id": { "type": ["string", "number", "null"] },
          "demand_kg": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
